# .env.example — Job Application Tracker
# Copy this file to .env and fill in real values before running docker compose.
# NEVER commit .env to version control. Only .env.example is committed.
#
# Local vs Production differences:
#   - *_HOST vars: use service names (e.g. "mysql") locally; use RDS/ElastiCache
#     endpoints in production.
#   - *_DB_URL: uses jdbc:mysql://mysql/... locally; RDS endpoint in production.
#   - SSL: not required locally; required on RDS (add ?useSSL=true&requireSSL=true
#     &verifyServerCertificate=true to the JDBC URL in production).
#   - JWT_SECRET: use a randomly generated 64-char string in production.
#     Generate with: openssl rand -hex 32
#   - Secrets in production should be injected via AWS Secrets Manager,
#     HashiCorp Vault, or CI/CD platform env injection — never stored in files.

# =============================================================================
# MySQL
# =============================================================================
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_USER=jat_app
MYSQL_PASSWORD=change_me_app_password

# Host port mapped to container port 3306 for local direct DB access.
# Change if 3306 is already occupied on your machine.
MYSQL_HOST_PORT=3306

# =============================================================================
# Per-service JDBC connection URLs
# Local:      jdbc:mysql://mysql/<db>?useSSL=false&allowPublicKeyRetrieval=true
# Production: jdbc:mysql://<rds-endpoint>:3306/<db>?useSSL=true&requireSSL=true
# =============================================================================
AUTH_DB_URL=jdbc:mysql://mysql/auth_db?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
AUTH_DB_USERNAME=jat_app
AUTH_DB_PASSWORD=change_me_app_password

APP_DB_URL=jdbc:mysql://mysql/application_db?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
APP_DB_USERNAME=jat_app
APP_DB_PASSWORD=change_me_app_password

NOTIF_DB_URL=jdbc:mysql://mysql/notification_db?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
NOTIF_DB_USERNAME=jat_app
NOTIF_DB_PASSWORD=change_me_app_password

# =============================================================================
# Redis
# Local host/port for application services connecting to the Redis container.
# REDIS_HOST should be "redis" when services run inside Docker network app-net,
# or "localhost" when running Spring Boot processes directly on the host.
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_HOST_PORT=6379    # host-side port mapping in docker-compose

# TTL for dashboard summary cache keys (app:dashboard:{userId}).
# Increase to reduce DB load; decrease for fresher data.
REDIS_DASHBOARD_TTL_MINUTES=5

# =============================================================================
# RabbitMQ
# =============================================================================
RABBITMQ_DEFAULT_USER=jat_rabbit
RABBITMQ_DEFAULT_PASS=change_me_rabbit_password

# RABBITMQ_HOST: use "rabbitmq" inside Docker network; "localhost" on bare host.
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_AMQP_PORT=5672    # host-side AMQP port mapping
RABBITMQ_MGMT_PORT=15672   # host-side management UI port mapping

# =============================================================================
# JWT
# Must be at least 32 characters. Use openssl rand -hex 32 to generate.
# This value MUST match across all services that validate tokens
# (auth-service, application-service, notification-service, gateway-service).
# =============================================================================
JWT_SECRET=replace_this_with_a_minimum_32_character_secret_value_here

# =============================================================================
# Service ports
# These are the ports each Spring Boot service binds to.
# In docker-compose.full.yml, these map HOST:CONTAINER.
# =============================================================================
GATEWAY_PORT=8080
AUTH_PORT=8081
APP_PORT=8082
NOTIF_PORT=8083

# =============================================================================
# Gateway downstream URIs (used by docker-compose.full.yml and AWS ECS)
# Local Docker: use Docker Compose service names as hostnames.
# AWS ECS:      ECS Service Connect provides DNS — same host names work.
# Bare-process: comment out; defaults to localhost:{port}.
# =============================================================================
AUTH_SERVICE_URI=http://auth-service:8081
APP_SERVICE_URI=http://application-service:8082
NOTIF_SERVICE_URI=http://notification-service:8083

# CORS allowed origin for the gateway.
# Local dev: http://localhost:5173 (Vite dev server)
# Production: https://<your-cloudfront-or-domain>
CORS_ALLOWED_ORIGIN=http://localhost:5173
