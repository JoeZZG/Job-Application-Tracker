# .env.example — copy to .env.local and fill in values
#
# Local dev → local backend (Vite proxy handles routing):
#   leave VITE_API_BASE_URL unset or empty
#
# Local dev → AWS staging backend:
#   VITE_API_BASE_URL=http://jat-staging-alb-334721464.us-east-1.elb.amazonaws.com
#
# Production build → AWS:
#   VITE_API_BASE_URL=http://jat-staging-alb-334721464.us-east-1.elb.amazonaws.com
VITE_API_BASE_URL=
